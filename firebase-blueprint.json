{
  "entities": {
    "LessonPlan": {
      "title": "Lesson Plan",
      "description": "Modul Ajar atau RPP Kurikulum Merdeka",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "grade": { "type": "string" },
        "topic": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "pancasilaProfiles": { "type": "array", "items": { "type": "string" } },
        "identifikasi": {
          "type": "object",
          "properties": {
            "pesertaDidik": { "type": "string" },
            "analisisMateri": { "type": "string" }
          }
        },
        "desain": {
          "type": "object",
          "properties": {
            "capaian": { "type": "string" },
            "lintasDisiplin": { "type": "string" },
            "tujuan": { "type": "string" },
            "praktik": { "type": "string" },
            "lingkungan": { "type": "string" },
            "teknologi": { "type": "string" }
          }
        },
        "pengalaman": {
          "type": "object",
          "properties": {
            "awal": { "type": "string" },
            "inti": { "type": "string" },
            "penutup": { "type": "string" }
          }
        },
        "asesmen": {
          "type": "object",
          "properties": {
            "awal": { "type": "string" },
            "proses": { "type": "string" },
            "akhir": { "type": "string" }
          }
        }
      },
      "required": ["userId", "subject", "grade", "topic"]
    }
  },
  "firestore": {
    "lessonPlans": {
      "schema": "LessonPlan",
      "description": "Collection of lesson plans created by teachers."
    }
  }
}
